func flattenPartitionIndexDescriptors(apiObjects []awstypes.PartitionIndexDescriptor) []any {
	if len(apiObjects) == 0 {
		return nil
	}

	var tfList []any

	for _, apiObject := range apiObjects {
		tfList = append(tfList, flattenPartitionIndexDescriptor(&apiObject))
	}

	return tfList
}
