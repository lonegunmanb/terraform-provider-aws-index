func flattenColumns(apiObjects []awstypes.Column) []any {
	tfList := make([]any, len(apiObjects))
	if len(apiObjects) > 0 {
		for i, apiObject := range apiObjects {
			tfList[i] = flattenColumn(apiObject)
		}
	}

	return tfList
}
