func hasPostCreateUpdate(data userResourceModel) bool {
	updateAttrs := []types.String{
		data.City,
		data.Company,
		data.Country,
		data.Department,
		data.Initials,
		data.JobTitle,
		data.Office,
		data.Street,
		data.Telephone,
		data.ZipCode,
	}
	for _, attr := range updateAttrs {
		if !attr.IsNull() && !attr.IsUnknown() {
			return true
		}
	}
	return false
}
