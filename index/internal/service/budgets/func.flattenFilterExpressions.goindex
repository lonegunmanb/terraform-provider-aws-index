func flattenFilterExpressions(apiObjects []awstypes.Expression) []map[string]any {
	if len(apiObjects) == 0 {
		return nil
	}

	result := make([]map[string]any, 0, len(apiObjects))
	for i := range apiObjects {
		result = append(result, flattenFilterExpression(&apiObjects[i])[0])
	}

	return result
}
