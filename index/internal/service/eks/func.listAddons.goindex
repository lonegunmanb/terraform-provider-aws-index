)
func listAddons(ctx context.Context, conn *eks.Client, input *eks.ListAddonsInput, optFns ...func(*eks.Options)) iter.Seq2[string, error] {
	return tfiter.ConcatValuesWithError(listAddonPages(ctx, conn, input, optFns...))
}
