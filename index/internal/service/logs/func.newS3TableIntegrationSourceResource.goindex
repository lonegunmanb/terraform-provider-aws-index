func newS3TableIntegrationSourceResource(_ context.Context) (resource.ResourceWithConfigure, error) {
	r := &s3TableIntegrationSourceResource{}

	r.SetDefaultDeleteTimeout(5 * time.Minute)

	return r, nil
}
