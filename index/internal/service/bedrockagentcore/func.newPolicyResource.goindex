func newPolicyResource(_ context.Context) (resource.ResourceWithConfigure, error) {
	r := &policyResource{}

	r.SetDefaultCreateTimeout(5 * time.Minute)
	r.SetDefaultUpdateTimeout(5 * time.Minute)
	r.SetDefaultDeleteTimeout(5 * time.Minute)

	return r, nil
}
