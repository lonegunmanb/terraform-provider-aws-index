func (serviceImportID) Parse(id string) (string, map[string]any, error) {
	cluster, service, err := parseServiceImportID(id)
	if err != nil {
		return "", nil, err
	}

	result := map[string]any{
		"cluster":      cluster,
		names.AttrName: service,
	}
	return id, result, nil
}
