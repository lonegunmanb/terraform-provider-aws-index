func newTelemetryEnrichmentResource(_ context.Context) (resource.ResourceWithConfigure, error) {
	r := &telemetryEnrichmentResource{}

	r.SetDefaultCreateTimeout(5 * time.Minute)
	r.SetDefaultDeleteTimeout(5 * time.Minute)

	return r, nil
}
