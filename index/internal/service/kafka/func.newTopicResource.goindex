func newTopicResource(_ context.Context) (resource.ResourceWithConfigure, error) {
	r := &topicResource{}

	r.SetDefaultCreateTimeout(30 * time.Minute)
	r.SetDefaultUpdateTimeout(30 * time.Minute)
	r.SetDefaultDeleteTimeout(30 * time.Minute)

	return r, nil
}
