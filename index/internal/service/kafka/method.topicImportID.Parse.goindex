func (topicImportID) Parse(id string) (string, map[string]any, error) {
	const (
		topicIDParts = 2
	)
	parts, err := intflex.ExpandResourceId(id, topicIDParts, true)

	if err != nil {
		return "", nil, err
	}

	result := map[string]any{
		"cluster_arn":  parts[0],
		names.AttrName: parts[1],
	}

	return id, result, nil
}
