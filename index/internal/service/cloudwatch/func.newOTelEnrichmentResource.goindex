func newOTelEnrichmentResource(_ context.Context) (resource.ResourceWithConfigure, error) {
	r := &otelEnrichmentResource{}

	r.SetDefaultCreateTimeout(5 * time.Minute)
	r.SetDefaultDeleteTimeout(5 * time.Minute)

	return r, nil
}
