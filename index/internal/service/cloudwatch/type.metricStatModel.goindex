type metricStatModel struct {
	Dimensions fwtypes.MapOfString                       `tfsdk:"dimensions"`
	MetricName types.String                              `tfsdk:"metric_name"`
	Namespace  types.String                              `tfsdk:"namespace"`
	Period     types.Int64                               `tfsdk:"period"`
