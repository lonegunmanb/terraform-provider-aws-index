type collectionGroupSummaryModel struct {
	ARN                 types.String                                                   `tfsdk:"arn"`
	CapacityLimits      fwtypes.ListNestedObjectValueOf[capacityLimitsDataSourceModel] `tfsdk:"capacity_limits"`
