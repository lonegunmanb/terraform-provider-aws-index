func layerNameFromARN(layerArn string) string {
	// Extract layer name from ARN: arn:aws:lambda:region:account:layer:name
	parts := strings.Split(layerArn, ":")
	if len(parts) >= 7 {
		return parts[6]
	}
	return ""
}
