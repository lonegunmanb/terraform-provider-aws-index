package github.com/hashicorp/terraform-provider-aws/internal/iter
import (
	"iter"
)
func ApplyToAll2[K1, K2, V1, V2 any](seq iter.Seq2[K1, V1], f func(K1, V1) (K2, V2)) iter.Seq2[K2, V2] {
	return func(yield func(K2, V2) bool) {
		for k, v := range seq {
			if !yield(f(k, v)) {
				return
			}
		}
	}
}
